!/tools/sufen_mystand_tools.py
!/tools/thread_context.py
!/tools/threat_patterns.py
!/tools/tool_result_storage.py
!/tools/url_safety.py
!/tools/web_tools.py

# First release keeps the OpenAI-compatible chat-completions transport used by
# DeepSeek and the normalized response types. Other inherited transports are
# outside the reviewed SuFen path.
/agent/transports/*.py
!/agent/transports/
!/agent/transports/__init__.py
!/agent/transports/base.py
!/agent/transports/chat_completions.py
!/agent/transports/types.py
