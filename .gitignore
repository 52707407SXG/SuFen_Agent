# SuFen first-release agent core. The full upstream tree stays locally as
# reference material, but the deliverable only carries the mature runtime
# pieces required by the plan: conversation loop, provider call path,
# prompt assembly, compression, memory interfaces, tool execution, and
# redaction/safety helpers.
/agent/*.py
/agent/*/
!/agent/
!/agent/__init__.py
!/agent/auxiliary_client.py
!/agent/chat_completion_helpers.py
!/agent/codex_responses_adapter.py
!/agent/context_compressor.py
!/agent/context_engine.py
!/agent/conversation_compression.py
!/agent/conversation_loop.py
!/agent/display.py
!/agent/error_classifier.py
!/agent/iteration_budget.py
!/agent/jiter_preload.py
!/agent/lmstudio_reasoning.py
!/agent/memory_manager.py
!/agent/memory_provider.py
!/agent/message_sanitization.py
!/agent/model_metadata.py
!/agent/moonshot_schema.py
!/agent/process_bootstrap.py
!/agent/prompt_builder.py
!/agent/prompt_caching.py
!/agent/redact.py
!/agent/retry_utils.py
!/agent/runtime_cwd.py
!/agent/secret_scope.py
!/agent/skill_commands.py
!/agent/skill_preprocessing.py
!/agent/skill_utils.py
!/agent/system_prompt.py
!/agent/tool_dispatch_helpers.py
!/agent/tool_executor.py
!/agent/tool_guardrails.py
!/agent/tool_result_classification.py
!/agent/trajectory.py
!/agent/turn_context.py
!/agent/turn_retry_state.py
!/agent/usage_pricing.py
!/agent/web_search_provider.py

# SuFen first-release tool surface. Keep the mature registry/executor support
# but do not ship inherited free terminal, code execution, browser automation,
# messaging gateways, filesystem mutation tools, cron/kanban, or media tools.
/tools/*.py
/tools/*/
!/tools/
!/tools/__init__.py
!/tools/budget_config.py
