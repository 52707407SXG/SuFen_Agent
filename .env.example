# SuFen-Agent environment template
# Copy to .env on a deployment host and fill SuFen-specific keys only.

SUFEN_PROVIDER=deepseek
SUFEN_MODEL=deepseek-v4-pro
SUFEN_API_KEY=
SUFEN_BASE_URL=
SUFEN_DELEGATION_HMAC_SECRET=
SUFEN_TAVILY_API_KEY=
SUFEN_MEMORY_ROOT=/var/lib/sufen-agent/memory
SUFEN_BIND_HOST=127.0.0.1
SUFEN_PORT=8791
SUFEN_FAKE_PROVIDER=0

# Optional local state root. Production service units usually set this to
# /var/lib/sufen-agent. Do not commit .env or any generated runtime files.
SUFEN_HOME=/var/lib/sufen-agent
